#!/bin/sh
# Auto-generate data/version.json before commit.
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Try python interpreters in order of likelihood
PY=""
for candidate in python3 python py; do
  if command -v "$candidate" >/dev/null 2>&1; then
    # Verify it actually runs (avoids Windows Store shim)
    if "$candidate" -c "import sys" >/dev/null 2>&1; then
      PY="$candidate"
      break
    fi
  fi
done

if [ -z "$PY" ]; then
  echo "pre-commit: no usable python found, skipping version gen" >&2
  exit 0
fi

"$PY" "$REPO_ROOT/scripts/gen_version.py" || {
  echo "pre-commit: gen_version.py failed" >&2
  exit 1
}

git add "$REPO_ROOT/data/version.json" "$REPO_ROOT/sw.js" "$REPO_ROOT/index.html"
