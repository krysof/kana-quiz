#!/bin/sh
# Auto-generate data/version.json with today's date + commit count
# and stage it before the commit proceeds.

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Use python3 if available, else python (Windows git-bash uses python)
PY=python
command -v python3 >/dev/null 2>&1 && PY=python3

"$PY" "$REPO_ROOT/scripts/gen_version.py" || {
  echo "pre-commit: gen_version.py failed" >&2
  exit 1
}

git add "$REPO_ROOT/data/version.json"
